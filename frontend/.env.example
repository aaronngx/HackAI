# ─── Database (required) ──────────────────────────────────────────────────────
MONGODB_URI=
MONGODB_DB=HackAI

# ─── Google Gemini AI (required) ──────────────────────────────────────────────
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── ElevenLabs TTS (required) ────────────────────────────────────────────────
# Get a key at https://elevenlabs.io — free tier works
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=

# ─── Google Places API (optional) ─────────────────────────────────────────────
# Enables real clinic search. Enable: Places API + Distance Matrix API.
# Without this key the app falls back to NPPES API then doctors.csv.
GOOGLE_PLACES_API_KEY=
